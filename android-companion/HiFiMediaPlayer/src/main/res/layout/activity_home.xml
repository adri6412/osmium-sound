<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/AppBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_home"
        app:title="@string/app_name" />

    <!-- Home Library Content with Tabs -->
    <include layout="@layout/home_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Now Playing Fragment at Bottom -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/now_playing_fragment"
        android:name="com.hifi.mediaplayer.NowPlayingFragment"
        style="@style/AppBarStyle"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        tools:layout="@layout/now_playing_fragment_mini"/>

</LinearLayout>
