<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0a">

    <!-- NOW PLAYING PANEL - Desktop-like layout for mobile -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- Spacer for vertical centering -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <!-- Artwork - Large Square like desktop (max width-constrained) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal">

            <include layout="@layout/volume_adjust"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Track Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/trackname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Track Name" />

            <TextView
                android:id="@+id/artistname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#D4AF37"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Artist"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/albumname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#808080"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Album"
                android:paddingTop="2dp" />
        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="1"
                android:stepSize="1"
                app:trackColorActive="#D4AF37"
                app:trackColorInactive="#2a2a2a"
                app:thumbColor="#D4AF37"
                app:thumbRadius="6dp"
                app:trackHeight="3dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/currenttime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#606060"
                    android:fontFamily="monospace"
                    android:text="0:00" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/totaltime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#606060"
                    android:fontFamily="monospace"
                    android:text="0:00" />
            </LinearLayout>
        </LinearLayout>

        <!-- Transport Controls - Like desktop (Previous - Play/Pause Large - Next) -->
        <LinearLayout
            android:id="@+id/media_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- Previous Button -->
            <FrameLayout
                android:id="@+id/prev"
                style="@style/GoldButtonContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="24dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_action_previous"
                    android:contentDescription="Previous"
                    android:tint="#ffffff" />
            </FrameLayout>

            <!-- Play/Pause -->
            <FrameLayout
                android:id="@+id/pause"
                style="@style/GoldButtonContainer"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_action_play"
                    android:contentDescription="Play/Pause"
                    android:tint="#ffffff" />
            </FrameLayout>

            <!-- Next Button -->
            <FrameLayout
                android:id="@+id/next"
                style="@style/GoldButtonContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="24dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_action_next"
                    android:contentDescription="Next"
                    android:tint="#ffffff" />
            </FrameLayout>
        </LinearLayout>

        <!-- Volume Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/volume_mute"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_action_volume"
                android:contentDescription="Mute"
                android:background="?attr/selectableItemBackground"
                android:scaleType="centerInside"
                android:tint="#808080" />

            <com.google.android.material.slider.Slider
                android:id="@+id/volume_slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:valueFrom="0"
                android:valueTo="100"
                android:stepSize="1"
                app:trackColorActive="#D4AF37"
                app:trackColorInactive="#2a2a2a"
                app:thumbColor="#D4AF37"
                app:thumbRadius="4dp"
                app:trackHeight="2dp" />

            <TextView
                android:id="@+id/volume_value"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#606060"
                android:gravity="right"
                android:fontFamily="monospace"
                android:text="100" />
        </LinearLayout>

        <!-- Spacer for vertical centering -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a2a" />

    <!-- TAB BAR and LIBRARY CONTENT - Bottom section for browsing -->
    <include layout="@layout/home_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
