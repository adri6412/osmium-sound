# HiFi Player - allow the kiosk user to run the system-control commands
# used by api_server.py without a password prompt.
#
# Keep these as TIGHT as possible: every entry here is reachable with the kiosk
# user's well-known default password, so a loose wildcard is a privilege-
# escalation path. In particular `apt-get upgrade *` is NOT used — the trailing
# wildcard would allow `-o DPkg::Pre-Invoke=<cmd>` / `-o APT::Update::Pre-Invoke`
# which run arbitrary commands as root. Pin the exact invocation instead.
hifi ALL=(ALL) NOPASSWD: /sbin/reboot, /sbin/shutdown, /usr/sbin/reboot, /usr/sbin/shutdown
hifi ALL=(ALL) NOPASSWD: /usr/bin/apt-get update, /usr/bin/apt-get upgrade -y, /usr/bin/apt-get install -y openssh-server
hifi ALL=(ALL) NOPASSWD: /sbin/dhclient, /usr/sbin/dhclient, /usr/bin/ip, /sbin/ip
hifi ALL=(ALL) NOPASSWD: /usr/bin/nmcli *
# SSH on/off toggle (Settings). Pin the exact unit names — no wildcard.
hifi ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable --now ssh.service, /usr/bin/systemctl disable --now ssh.service, /usr/bin/systemctl enable --now sshd.service, /usr/bin/systemctl disable --now sshd.service
